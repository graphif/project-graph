{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "namedInputs": {
    "default": ["{projectRoot}/src/**/*", "sharedGlobals"],
    "sharedGlobals": ["{workspaceRoot}/*.config.{js,ts,json}", "{workspaceRoot}/tsconfig.json"],
    "production": ["default"]
  },
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"],
      "outputs": ["{projectRoot}/dist/**"],
      "cache": true
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "continuous": true
    },
    "tauri:dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "continuous": true
    },
    "tauri:build": {
      "dependsOn": ["build", "^build"],
      "outputs": ["{projectRoot}/src-tauri/target/release/bundle/**"],
      "cache": true
    },
    "type-check": {
      "inputs": ["{projectRoot}/src/**/*.{ts,tsx}"],
      "cache": true
    },
    "publish": {
      "dependsOn": ["build"],
      "cache": false
    }
  },
  "defaultBase": "next",
  "analytics": false
}
