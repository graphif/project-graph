{
  "name": "@graphif/shapes",
  "targets": {
    "build": {
      "dependsOn": ["^build"],
      "cache": true,
      "outputs": ["{projectRoot}/dist/**"]
    },
    "type-check": {
      "cache": true,
      "inputs": ["{projectRoot}/src/**/*.ts"]
    },
    "publish": {
      "dependsOn": ["build"],
      "cache": false
    }
  }
}
